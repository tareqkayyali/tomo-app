# Dependencies
node_modules/
# The Expo web export bundles its runtime assets under this path — they
# must ship with the build, so override the node_modules rule there.
!backend/public/webapp/assets/node_modules/
!backend/public/webapp/assets/node_modules/**

# Environment
.env
.env.local
.env.vercel
.env.seed
.env.production
.env.production.backup
*.env.production.backup

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Build outputs
backend/.next/
backend/out/
backend/build/

# Supabase
backend/supabase/.branches
backend/supabase/.temp

# Keep env templates
!backend/.env.local.local
!backend/.env.local.production
.vercel

# Zep CE Environment Variables
# Set these in Railway dashboard for the tomo-zep service

# PostgreSQL connection — use Supabase PgBouncer (port 6543) for connection pooling
# Format: postgres://user:password@host:6543/postgres?sslmode=require
ZEP_STORE_POSTGRES_DSN=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Auth secret — random 32+ character string for API key authentication
# Generate with: openssl rand -hex 32
ZEP_AUTH_SECRET=your-random-secret-key-here

# Memory configuration
ZEP_MEMORY_SEARCH_SCOPE=12
ZEP_EXTRACTORS_ENABLED=true

# LLM for entity extraction (Zep CE uses its own LLM calls)
# For Zep CE 0.25+, set the Anthropic API key for extraction
ZEP_LLM_ANTHROPIC_API_KEY=your-anthropic-key
ZEP_LLM_MODEL=claude-haiku-4-5-20251001

# Logging
ZEP_LOG_LEVEL=info

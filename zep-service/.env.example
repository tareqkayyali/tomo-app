# Zep CE Environment Variables
# Set these in Railway dashboard for the tomo-zep service
#
# IMPORTANT: Zep CE REQUIRES an OpenAI API key — it uses OpenAI for:
#   - Entity extraction (GPT-3.5-turbo)
#   - Embeddings (text-embedding-ada-002)
#   - Session summarization
# Cost: ~$1-2/month at 50K MAU (embeddings are extremely cheap)
# Get a free key at: https://platform.openai.com/api-keys

# PostgreSQL connection — use Supabase PgBouncer (port 6543) for connection pooling
# Format: postgres://user:password@host:6543/postgres?sslmode=require
ZEP_STORE_POSTGRES_DSN=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Auth secret — random 32+ character string for API key authentication
# Generate with: openssl rand -hex 32
ZEP_AUTH_SECRET=your-random-secret-key-here

# OpenAI API key — REQUIRED by Zep CE for entity extraction + embeddings
# Sign up free at https://platform.openai.com → API keys → Create new key
ZEP_OPENAI_API_KEY=sk-your-openai-key-here

# Logging
ZEP_LOG_LEVEL=info

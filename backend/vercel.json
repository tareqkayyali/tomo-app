{
  "functions": {
    "app/api/v1/recommendations/refresh/route.ts": {
      "maxDuration": 60
    },
    "app/api/v1/chat/*/route.ts": {
      "maxDuration": 60
    },
    "app/api/v1/for-you/route.ts": {
      "maxDuration": 60
    },
    "app/api/v1/events/bridge-calendar/route.ts": {
      "maxDuration": 60
    },
    "app/api/v1/notifications/triggers/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/v1/events/bridge-calendar",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/v1/notifications/triggers",
      "schedule": "*/15 * * * *"
    }
  ]
}

{
  "$schema": "https://design-tokens.org/schema.json",
  "color": {
    "ink":        { "$value": "#12141F", "$type": "color", "$description": "Primary dark · backgrounds, text on light" },
    "ink-hover":  { "$value": "#1E202D", "$type": "color", "$description": "Dark surface hover · elevated card bg on dark" },
    "cream":      { "$value": "#F5F3ED", "$type": "color", "$description": "Primary light · backgrounds, text on dark" },
    "sage":       { "$value": "#7A9B76", "$type": "color", "$description": "Accent · presence, active states, focus" },
    "sage-dim":   { "$value": "#9AB896", "$type": "color", "$description": "Sage variant for dark surfaces" },
    "clay":       { "$value": "#C8A27A", "$type": "color", "$description": "Warmth · match-day, events" },
    "steel":      { "$value": "#8A9BB0", "$type": "color", "$description": "Cool · recovery, calm states" },
    "muted":      { "$value": "#6B6E7A", "$type": "color", "$description": "Secondary text, disabled" },
    "divider":    { "$value": "#2A2D38", "$type": "color", "$description": "Dividers on dark surfaces" }
  },
  "font": {
    "family": {
      "sans":     { "$value": "Poppins, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "light":    { "$value": 300, "$type": "fontWeight" },
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" }
    },
    "size": {
      "xs":      { "$value": "11px",  "$type": "dimension" },
      "sm":      { "$value": "13px",  "$type": "dimension" },
      "base":    { "$value": "15px",  "$type": "dimension" },
      "lg":      { "$value": "17px",  "$type": "dimension" },
      "xl":      { "$value": "20px",  "$type": "dimension" },
      "2xl":     { "$value": "24px",  "$type": "dimension" },
      "3xl":     { "$value": "32px",  "$type": "dimension" },
      "4xl":     { "$value": "48px",  "$type": "dimension" },
      "display": { "$value": "64px",  "$type": "dimension" },
      "mark":    { "$value": "120px", "$type": "dimension", "$description": "Wordmark scale" }
    },
    "tracking": {
      "wordmark":  { "$value": "-0.035em", "$type": "dimension", "$description": "tomo wordmark: Medium, -3.5%" },
      "display":   { "$value": "-0.03em",  "$type": "dimension" },
      "body":      { "$value": "-0.01em",  "$type": "dimension" },
      "label":     { "$value": "0.2em",    "$type": "dimension", "$description": "Uppercase mono labels" }
    }
  },
  "space": {
    "0.5": { "$value": "4px",   "$type": "dimension" },
    "1":   { "$value": "8px",   "$type": "dimension" },
    "1.5": { "$value": "12px",  "$type": "dimension" },
    "2":   { "$value": "16px",  "$type": "dimension" },
    "2.5": { "$value": "20px",  "$type": "dimension" },
    "3":   { "$value": "24px",  "$type": "dimension" },
    "4":   { "$value": "32px",  "$type": "dimension" },
    "5":   { "$value": "40px",  "$type": "dimension" },
    "7":   { "$value": "56px",  "$type": "dimension" },
    "10":  { "$value": "80px",  "$type": "dimension" },
    "15":  { "$value": "120px", "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "8px",   "$type": "dimension" },
    "md":   { "$value": "12px",  "$type": "dimension" },
    "lg":   { "$value": "16px",  "$type": "dimension" },
    "xl":   { "$value": "24px",  "$type": "dimension" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },
  "shadow": {
    "1": { "$value": "0 2px 6px rgba(0,0,0,0.10)",   "$type": "shadow" },
    "2": { "$value": "0 8px 24px rgba(0,0,0,0.18)",  "$type": "shadow" },
    "3": { "$value": "0 20px 60px rgba(0,0,0,0.40)", "$type": "shadow" }
  },
  "icon": {
    "stroke":   { "$value": "1.5px", "$type": "dimension" },
    "viewBox":  { "$value": "0 0 20 20", "$type": "other" },
    "sizes": {
      "sm":  { "$value": "16px", "$type": "dimension" },
      "md":  { "$value": "20px", "$type": "dimension" },
      "lg":  { "$value": "24px", "$type": "dimension" },
      "xl":  { "$value": "28px", "$type": "dimension" }
    }
  },
  "bond": {
    "viewBox":   { "$value": "-5 22 110 56", "$type": "other" },
    "stroke":    { "$value": "7", "$type": "dimension", "$description": "Stroke width in viewBox units (7 / 100 = 7%)" },
    "aperture":  { "$value": "5deg", "$type": "other", "$description": "Angular cut on each circle's outer end" },
    "minSize":   { "$value": "16px", "$type": "dimension" },
    "clearSpace":{ "$value": "0.26", "$type": "other", "$description": "Clear space as fraction of mark width" }
  }
}

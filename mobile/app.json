{
  "expo": {
    "name": "tomo",
    "slug": "tomo",
    "scheme": "tomo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#12141F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tomo.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Tomo reads your sleep, heart rate, workouts, and activity data to track recovery and optimize training.",
        "NSCameraUsageDescription": "Tomo uses the camera to record your training drills so you can review your form.",
        "NSPhotoLibraryUsageDescription": "Tomo accesses your photo library to set a profile photo and save drill recordings.",
        "NSMicrophoneUsageDescription": "Tomo records audio with your training drill videos.",
        "NSMotionUsageDescription": "Tomo uses motion sensors to measure your jump height, sprint speed, agility, and balance during phone-based tests."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": [
          "health-records"
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.tomo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F3ED"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "assets/**/*",
      "assets/rive/*"
    ],
    "extra": {
      "eas": {
        "projectId": "7cd0fd4e-b7fa-4bd0-8eb5-b15808e224cc"
      },
      "supabaseUrl": "https://ydtnhxqwvtnypjisaavm.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlkdG5oeHF3dnRueXBqaXNhYXZtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMyMzYyMjgsImV4cCI6MjA4ODgxMjIyOH0.zCvxo28-pCQ__B82G8yD6Ly_7HMMmUwP3A2gy9YL4NU",
      "apiUrl": "https://app.my-tomo.com"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Tomo uses the camera to record your training drills so you can review your form.",
          "microphonePermission": "Tomo records audio with your training drill videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Tomo accesses your photos to set a profile picture.",
          "cameraPermission": "Tomo uses the camera to take a profile photo."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Tomo reads your sleep, heart rate, workouts, and activity data to track recovery and optimize training.",
          "NSHealthUpdateUsageDescription": "Tomo does not write health data."
        }
      ],
      "expo-notifications",
      "expo-sensors",
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "organization": "SENTRY_ORG_PLACEHOLDER",
          "project": "SENTRY_PROJECT_PLACEHOLDER"
        }
      ],
      "expo-audio",
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "owner": "tomo2026"
  }
}
